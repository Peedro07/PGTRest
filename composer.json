{
    "name": "peedro07/pgt-rest",
    "description": "This bundle is designed to facilitate the creation of api rest with symfony",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.2",
        "symfony/http-foundation": ">=6.0,<7.0.*",
        "symfony/event-dispatcher": ">=6.0,<7.0.*",
        "symfony/http-kernel": ">=6.0,<7.0.*",
        "symfony/framework-bundle": ">=6.0,<7.0.*",
        "symfony/serializer": ">=6.0,<7.0.*",
        "symfony/dependency-injection": ">=6.0,<7.0.*",
        "doctrine/annotations": "^2.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PGTRest\\": ""
        }
    },
    "authors": [
        {
            "name": "Waflart Pierre",
            "email": "contact@pierre-waflart.fr"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
